{
  "name": "camp-swing-outdoor-fe",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build pipeline for Camp Swing Outdoor (Spring Boot + Thymeleaf)",
  "scripts": {
    "css:dev": "tailwindcss -i ./src/styles/app.css -o ./src/main/resources/static/css/app.css --watch",
    "css:build": "tailwindcss -i ./src/styles/app.css -o ./src/main/resources/static/css/app.css --minify",
    "js:copy": "cp node_modules/alpinejs/dist/cdn.min.js src/main/resources/static/js/alpine.min.js"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.10",
    "postcss": "^8.4.41",
    "autoprefixer": "^10.4.20",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "alpinejs": "^3.14.1"
  }
}
